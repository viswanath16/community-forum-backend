{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "framework": "node",
  "regions": ["iad1"],
  "installCommand": "npm install --include=dev",
  "builds": [
    {
      "src": "api/**/*.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth/[...route].ts"
    },
    {
      "src": "/api/marketplace/(.*)",
      "dest": "/api/marketplace/[...route].ts"
    },
    {
      "src": "/api/posts/(.*)",
      "dest": "/api/posts/[...route].ts"
    },
    {
      "src": "/api/events/(.*)",
      "dest": "/api/events/[...route].ts"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.ts"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}