# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_should_be_long_and_random
JWT_EXPIRES_IN=1d

# Database Connection
# For local development
DATABASE_URL="postgresql://postgres:password@localhost:5432/community_forum"

# For production with connection pooling (Vercel, etc.)
# DATABASE_URL="postgres://user:password@pooler.example.com:5432/database_name"
# DIRECT_URL="postgres://user:password@host.example.com:5432/database_name"